# TashanScene工作室部署示例配置
# 复制为 .env.local 或部署平台环境变量后填写真实值。

# 站点公网地址，用于服务端回调、内部 API 访问和生成任务资源引用。
TASHANSCENE_PROJECT_DOMAIN_DEFAULT=https://your-domain.example.com
INTERNAL_API_BASE=https://your-domain.example.com

# 火山引擎 TTS。
VOLCENGINE_TTS_API_KEY=

# 对象存储，用于上传素材、生成结果持久化，以及真实分段视频的尾帧 handoff。
# 如果要让上一段 lastFrame 作为下一段 firstFrame 传给 Ark/视频供应商，必须配置公网可访问的 bucket。
TASHANSCENE_OBJECT_STORAGE_ENDPOINT_URL=
TASHANSCENE_OBJECT_STORAGE_BUCKET_NAME=
TASHANSCENE_OBJECT_STORAGE_ACCESS_KEY_ID=
TASHANSCENE_OBJECT_STORAGE_SECRET_ACCESS_KEY=
TASHANSCENE_OBJECT_STORAGE_REGION=cn-beijing
# 可选替代：无对象存储时，把本地 FFmpeg 抽出的尾帧写入 public/generated/frames。
# 必须是可被视频供应商访问的 HTTPS 公网地址；localhost/内网地址不会被视为 handoff ready。
TASHANSCENE_PUBLIC_ASSET_BASE_URL=

# 用户自带密钥 BYOK：
# 用户在设置页填写 API Base / API Key 后，密钥保存在浏览器 localStorage。
# 服务端只在连接测试和生成请求期间接收请求级密钥，不应把用户密钥写入环境变量或日志。
# 默认禁止用户 API Base 指向 localhost、内网或链路本地地址，避免公网部署 SSRF 风险。
# 仅在可信本地调试或私有网关部署时设置为 true。
YH_BYOK_ALLOW_PRIVATE_API_BASE=false

# 自动化真实 Ark 视频门控（仅本地授权测试时填写；不要提交真实 Key）。
# 默认 `pnpm run qa:real-video-gate` 不会读取真实 Key、不调用供应商、不产生费用。
TASHANSCENE_BASE_URL=http://localhost:5000
TASHANSCENE_REAL_ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
TASHANSCENE_REAL_ARK_API_KEY=
TASHANSCENE_REAL_ARK_VIDEO_MODEL=
TASHANSCENE_REAL_VIDEO_SECONDS=5
TASHANSCENE_REAL_VIDEO_MAX_SECONDS=10
TASHANSCENE_ALLOW_REAL_VIDEO_COST=false
# 只有 5s smoke、2 段 handoff 和对象存储 readiness 都通过后，才临时改为 true 跑 60s 回归。
TASHANSCENE_ALLOW_REAL_60S_REGRESSION=false
